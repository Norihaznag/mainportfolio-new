# ─── Site ───────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://azinag.site

# ─── WhatsApp Contact ────────────────────────────────────────────────────────
# International format WITHOUT + or spaces: 212XXXXXXXXX
NEXT_PUBLIC_WHATSAPP_PHONE=212609343953

# ─── Supabase ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_KEY=your_supabase_service_role_key_here

# ─── Admin Auth ──────────────────────────────────────────────────────────────
ADMIN_EMAIL=admin@azinag.site
ADMIN_PASSWORD=change-this-to-a-strong-password
ADMIN_SECRET_KEY=change-this-to-a-32-char-random-secret

# ─── Email (Resend) ──────────────────────────────────────────────────────────
RESEND_API_KEY=re_your_resend_api_key
CONTACT_EMAIL=contact@azinag.site

# ─── Download Links ──────────────────────────────────────────────────────────
# These are currently routed to WhatsApp for manual delivery.
# When you have real download links, update apps-data.ts platform URLs:
#
#   platforms: {
#     windows: { url: 'https://github.com/your-org/app/releases/latest/download/app-setup.exe', ... }
#     macos:   { url: 'https://github.com/your-org/app/releases/latest/download/app.dmg', ... }
#     linux:   { url: 'https://github.com/your-org/app/releases/latest/download/app.AppImage', ... }
#     ios:     { appStoreUrl: 'https://apps.apple.com/app/id...' }
#     android: { playStoreUrl: 'https://play.google.com/store/apps/details?id=...' }
#     web:     { liveUrl: 'https://app.example.com' }
#   }

# ─── Analytics (Optional) ───────────────────────────────────────────────────
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
# NEXT_PUBLIC_META_PIXEL_ID=your_pixel_id_here
