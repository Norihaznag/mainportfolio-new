# ─── Site ───────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://azinag.site

# ─── WhatsApp ────────────────────────────────────────────────────────────────
# Phone number in international format without + or spaces
# Example: 212612345678  (for +212 6 12 34 56 78)
NEXT_PUBLIC_WHATSAPP_PHONE=212609343953

# ─── Supabase ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_KEY=your_supabase_service_role_key_here

# ─── Admin auth ──────────────────────────────────────────────────────────────
ADMIN_EMAIL=admin@azinag.site
ADMIN_PASSWORD=change-this-strong-password
ADMIN_SECRET_KEY=change-this-to-a-long-random-secret-at-least-32-chars

# ─── Email (Resend) ──────────────────────────────────────────────────────────
RESEND_API_KEY=re_your_resend_api_key
CONTACT_EMAIL=contact@azinag.site

# ─── Analytics ──────────────────────────────────────────────────────────────
# Google Analytics GA4 measurement ID (optional)
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Meta Pixel ID (optional)
# NEXT_PUBLIC_META_PIXEL_ID=your_pixel_id_here
